      "id": 1,
      "title": "PV Power",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-yellow", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "green", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "" },
          "query": "from(bucket: \"solar\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"easun_3kw\")\n  |> filter(fn: (r) => r[\"_field\"] == \"pv_input_power\")\n  |> last()"
        }
      ]
    },
